{
  "name": "diagbridge-mcp",
  "version": "0.2.1",
  "private": true,
  "description": "General Windows MCP bridge for trusted local and remote AI agents.",
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-strip-types src/bridge.test.ts",
    "dev": "node --experimental-strip-types src/mcp/transports/stdio.ts",
    "dev:mcp": "node --experimental-strip-types src/mcp/transports/stdio.ts",
    "dev:remote-mcp": "node --experimental-strip-types src/mcp/transports/streamable-http.ts",
    "dev:http-mcp": "node --experimental-strip-types src/mcp/transports/streamable-http.ts",
    "dev:friend-ui": "node --experimental-strip-types src/ui/launch-friend-ui.ts",
    "build": "node build.js",
    "build:portable": "node build.js && node build-portable.js"
  },

  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.3"
  }
}
