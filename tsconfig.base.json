{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@diagbridge/core": ["packages/core/src/index.ts"],
      "@diagbridge/protocol": ["packages/protocol/src/index.ts"],
      "@diagbridge/policy": ["packages/policy/src/index.ts"],
      "@diagbridge/diagnostics": ["packages/diagnostics/src/index.ts"],
      "@diagbridge/redaction": ["packages/redaction/src/index.ts"],
      "@diagbridge/playbooks": ["packages/playbooks/src/index.ts"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "packages/**/*.ts"
  ]
}
